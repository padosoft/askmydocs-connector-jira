{
    "name": "padosoft/askmydocs-connector-jira",
    "description": "Jira Cloud connector for AskMyDocs — OAuth 2.0 3LO sync + ADF→markdown rendering + JQL incremental sync + structured-field frontmatter. Drop-in Laravel package that auto-registers via composer extra discovery.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "laravel",
        "askmydocs",
        "jira",
        "atlassian",
        "oauth",
        "rag",
        "knowledge-base",
        "padosoft"
    ],
    "authors": [
        {
            "name": "Lorenzo Padovani",
            "email": "lorenzo.padovani@padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0",
        "padosoft/askmydocs-connector-base": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0",
        "orchestra/testbench": "^10.0|^11.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.18"
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\AskMyDocsConnectorJira\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\AskMyDocsConnectorJira\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\AskMyDocsConnectorJira\\JiraServiceProvider"
            ]
        },
        "askmydocs": {
            "connectors": [
                "Padosoft\\AskMyDocsConnectorJira\\JiraConnector"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "format": "vendor/bin/pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "_comment": "TODO(lorenzo): remove this entry once padosoft/askmydocs-connector-base is live on Packagist. Until then CI resolves the base package directly from its GitHub VCS repo via the v1.1.1 tag.",
            "type": "vcs",
            "url": "https://github.com/padosoft/askmydocs-connector-base"
        }
    ]
}
